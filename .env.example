# Wedding Bazaar Frontend - Environment Variables
# Copy to .env.local for local development
# Set these in Vercel's Environment Variables for production

# ===========================================
# API URL
# ===========================================
# Local development (XAMPP):
NEXT_PUBLIC_API_URL=http://localhost/wedding-bazaar-next/api

# Production (Railway):
# NEXT_PUBLIC_API_URL=https://your-api.up.railway.app

# ===========================================
# CLOUDINARY (Image Uploads)
# ===========================================
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=your-upload-preset

# ===========================================
# PAYMONGO (Payments - Public Key Only)
# ===========================================
NEXT_PUBLIC_PAYMONGO_PUBLIC_KEY=pk_test_xxx
