# Wedding Bazaar API - Environment Variables
# Copy this to .env for local development
# For Railway: Use these as variable references in the Variables tab

# ===========================================
# DATABASE (Railway MySQL - use references)
# ===========================================
# Local development:
DB_HOST=localhost
DB_PORT=3306
DB_NAME=wedding_bazaar
DB_USER=root
DB_PASS=

# Railway production (set these in Variables tab):
# DB_HOST=${{MySQL.MYSQLHOST}}
# DB_PORT=${{MySQL.MYSQLPORT}}
# DB_NAME=${{MySQL.MYSQLDATABASE}}
# DB_USER=${{MySQL.MYSQLUSER}}
# DB_PASS=${{MySQL.MYSQLPASSWORD}}

# ===========================================
# SECURITY
# ===========================================
JWT_SECRET=your-super-secure-jwt-secret-key-min-32-chars

# ===========================================
# CORS - Frontend URL
# ===========================================
# Local:
FRONTEND_URL=http://localhost:3000
# Production: https://your-app.vercel.app

# ===========================================
# CLOUDINARY (Image Uploads)
# ===========================================
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ===========================================
# PAYMONGO (Payments)
# ===========================================
PAYMONGO_SECRET_KEY=sk_test_xxx
PAYMONGO_PUBLIC_KEY=pk_test_xxx
